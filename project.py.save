def hartreefock():
 vector2 = listtwobodymatrixelement()
 hw = 1
 p = random.rand(16,16)
 p /= np.trace(p)
 eigen = np.linalg.eig(p)
 V = random.rand(16,16)
 V = 0.5 * (V + V.T)
 Hab = hw * (1.5)
 i = 0
