def listsingleparticlestate():
 n = 0.0
 l = 0.0
 vector1 = []
 for j in range(0,2):
  tz = (j*1.) - 0.5
  for i in range(0,2):
   ang = (i*1.) - 0.5
   if i == 0:
    for k in range(0,2):
     angz = (k*1.) - 0.5
     vector1.append([n,l,ang,angz,tz])
   elif i == 1:
    for w in range(0,4):
     ang = 1.5
     angz = (w*1.) - 1.5
     vector1.append([n,l,ang,angz,tz])
    for z in range(0,2):
     ang = 0.5
     angz = (z*1.) - 0.5
     vector1.append([n,l,ang,angz,tz])
 return vector1

def listtwobodymatrixelement():
