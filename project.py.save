   ltot = vector1[i][1] + vector1[j][1]
   mj1 = vector1[i][3]
   mj2 = vector1[j][3]
   random = 0
   if vector1[i][1] == vector1[j][1] and vector1[i][2] == vector1[j][2] and mj1 + mj2 == 0:
    random_values = [[np.random.rand() for i in range(len(vector1))] for j in range(len(vector1))]
    vector2.append((vector1[i],vector1[j],random[i][j]))
 for i in vector2:
  print(i)
 print(len(vector2))

 return vector2

